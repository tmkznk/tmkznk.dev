---
/**
 * Decorative topographic background — the "Topographic Engineering" motif.
 * Purely decorative: hidden from assistive tech and excluded from tab order.
 * The glowing route pulses subtly (6s) and stops when reduced motion is set.
 */
---

<div
	class="pointer-events-none absolute inset-0 -z-10 overflow-hidden"
	aria-hidden="true"
>
	<svg
		class="absolute -right-24 -top-16 h-[140%] w-[120%] max-w-none sm:right-0 sm:w-[80%] lg:w-[60%]"
		viewBox="0 0 600 800"
		fill="none"
		preserveAspectRatio="xMidYMid slice"
		role="presentation"
	>
		<defs>
			<radialGradient id="topo-fade" cx="70%" cy="30%" r="70%">
				<stop offset="0%" stop-color="white" stop-opacity="1" />
				<stop offset="100%" stop-color="white" stop-opacity="0" />
			</radialGradient>
			<mask id="topo-mask">
				<rect width="600" height="800" fill="url(#topo-fade)" />
			</mask>
			<filter id="topo-glow" x="-50%" y="-50%" width="200%" height="200%">
				<feGaussianBlur stdDeviation="6" result="blur" />
				<feMerge>
					<feMergeNode in="blur" />
					<feMergeNode in="SourceGraphic" />
				</feMerge>
			</filter>
		</defs>

		<!-- Contour lines -->
		<g
			mask="url(#topo-mask)"
			stroke="var(--color-ink-secondary)"
			stroke-opacity="0.18"
			stroke-width="1.25"
			fill="none"
		>
			<path d="M520 -40C400 80 540 200 460 320 380 440 520 560 440 720" />
			<path d="M560 -20C450 110 590 230 500 350 410 470 560 590 470 760" />
			<path d="M480 0C370 120 500 230 420 350 340 470 480 580 400 740" />
			<path d="M440 40C340 150 460 250 390 360 320 470 450 570 380 720" />
			<path d="M600 40C500 150 620 260 540 380 460 500 600 600 520 780" />
			<path d="M400 80C310 180 420 270 360 380 300 490 410 580 350 720" />
			<path d="M360 140C290 230 380 310 330 410 280 510 370 590 320 710" />
		</g>

		<!-- Glowing exploration route -->
		<g
			class="origin-center motion-safe:animate-path-glow"
			filter="url(#topo-glow)"
		>
			<path
				d="M300 700C360 600 280 540 340 460 400 380 320 320 380 240 430 175 410 140 450 90"
				stroke="var(--color-accent)"
				stroke-width="2"
				stroke-dasharray="2 8"
				stroke-linecap="round"
				fill="none"
			/>
			<!-- Route nodes -->
			<circle cx="340" cy="460" r="4" fill="var(--color-accent-hover)" />
			<circle cx="380" cy="240" r="4" fill="var(--color-accent-hover)" />
			<circle cx="300" cy="700" r="3" fill="var(--color-accent-hover)" />

			<!-- Destination pin -->
			<g transform="translate(438 70)">
				<path
					d="M12 0C5.4 0 0 5.4 0 12c0 9 12 22 12 22s12-13 12-22C24 5.4 18.6 0 12 0z"
					fill="var(--color-accent)"
				/>
				<circle cx="12" cy="12" r="5" fill="var(--color-bg)" />
			</g>
		</g>
	</svg>
</div>
