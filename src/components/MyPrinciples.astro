---
/**
 * My principles — three principles in one surface card with vertical
 * dividers (per img2.png). Icons are design-system style: outline,
 * 2px stroke, accent color.
 */
const principles = [
	{
		icon: "shield",
		title: "Build to last",
		desc: "I focus on long-term solutions, not quick workarounds.",
	},
	{
		icon: "users",
		title: "User first",
		desc: "Great products start with understanding real user needs.",
	},
	{
		icon: "code",
		title: "Keep it simple",
		desc: "Clean code, clear architecture and small, focused steps.",
	},
];
---

<section class="container-page" aria-labelledby="principles-heading">
	<h2 id="principles-heading" class="eyebrow">My principles</h2>

	<ul
		class="card mt-6 grid list-none gap-8 sm:grid-cols-3 sm:gap-0 sm:divide-x sm:divide-border"
		role="list"
	>
		{
			principles.map((principle) => (
				<li class="flex flex-col gap-3 sm:px-8 sm:first:pl-0 sm:last:pr-0">
					<span class="text-accent" aria-hidden="true">
						{principle.icon === "shield" && (
							<svg class="h-7 w-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
								<path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z" />
								<path d="m9 12 2 2 4-4" />
							</svg>
						)}
						{principle.icon === "users" && (
							<svg class="h-7 w-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
								<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" />
								<circle cx="9" cy="7" r="4" />
								<path d="M22 21v-2a4 4 0 0 0-3-3.87" />
								<path d="M16 3.13a4 4 0 0 1 0 7.75" />
							</svg>
						)}
						{principle.icon === "code" && (
							<svg class="h-7 w-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
								<polyline points="16 18 22 12 16 6" />
								<polyline points="8 6 2 12 8 18" />
							</svg>
						)}
					</span>
					<h3 class="text-card-title">{principle.title}</h3>
					<p class="text-small text-ink-secondary">{principle.desc}</p>
				</li>
			))
		}
	</ul>
</section>
