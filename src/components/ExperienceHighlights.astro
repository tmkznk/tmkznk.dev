---
const stats = [
	{
		value: "18+",
		label: "years building for the web",
		icon: "calendar",
	},
	{
		value: "10+",
		label: "years of experience",
		icon: "user",
	},
	{
		value: "50+",
		label: "projects delivered",
		icon: "code",
	},
	{
		value: "25+",
		label: "happy teams & clients",
		icon: "pin",
	},
];
---

<section class="container-page" aria-labelledby="experience-heading">
	<h2 id="experience-heading" class="eyebrow">Experience highlights</h2>

	<dl class="mt-6 grid grid-cols-2 gap-4 md:grid-cols-4">
		{
			stats.map((stat) => (
				<div class="card flex flex-col gap-3">
					<div class="flex items-start justify-between gap-3">
						<dd class="text-section font-bold leading-none text-ink">
							{stat.value}
						</dd>
						<span class="shrink-0 text-accent" aria-hidden="true">
							{stat.icon === "calendar" && (
								<svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<rect x="3" y="4" width="18" height="18" rx="2" />
									<line x1="16" y1="2" x2="16" y2="6" />
									<line x1="8" y1="2" x2="8" y2="6" />
									<line x1="3" y1="10" x2="21" y2="10" />
								</svg>
							)}
							{stat.icon === "user" && (
								<svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2" />
									<circle cx="12" cy="7" r="4" />
								</svg>
							)}
							{stat.icon === "code" && (
								<svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<polyline points="16 18 22 12 16 6" />
									<polyline points="8 6 2 12 8 18" />
								</svg>
							)}
							{stat.icon === "pin" && (
								<svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z" />
									<circle cx="12" cy="10" r="3" />
								</svg>
							)}
						</span>
					</div>
					<dt class="text-small text-ink-secondary">{stat.label}</dt>
				</div>
			))
		}
	</dl>
</section>
