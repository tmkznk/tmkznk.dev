---
/**
 * Selected Work — open layout (no card wrapper), echoing the hero.
 * Projects are data-driven; each renders as a two-column block with the
 * product screenshot alternating sides by index parity.
 *
 * TODO: swap the placeholder images for real screenshots once added to
 * src/assets/work/ (diet-app.png, pagebuilder.png, kairoslist.png).
 */
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import placeholder from "../assets/work/placeholder.png";
import pagebuilder from "../assets/work/page-builder.png";
import app from "../assets/work/diet-and-training-app.png";
import kairos from "../assets/work/kairos-list.png";

type Project = {
	title: string;
	description: string;
	tags: string[];
	image: ImageMetadata;
	alt: string;
};

const projects: Project[] = [
	{
		title: "Diet & Training App",
		description:
			"White-label nutrition and training platform for fitness influencers — including Anna Lewandowska, Noelle Benepe, Victoria Loza, Nicci Robinson and more. Built the nutrition, body-measurement (with progress charts), hydration, achievements and knowledge-base modules, plus an AI meal & workout tracker that logs entries via text, photo, voice or barcode — recognizing food and breaking it down into ingredients, macros and calories.",
		tags: [
			"React",
			"TypeScript",
			"Apollo GraphQL",
			"Nx monorepo",
			"Bootstrap",
			"Firebase",
		],
		image: app,
		alt: "White-label diet and training app interface.",
	},
	{
		title: "Page Builder",
		description:
			"A block-based landing-page generator: 18 reusable sections, each with defined fields and five light/dark color themes. Pages are assembled like building blocks and populated in Strapi — copy, images and video. Extended with an AI generator that scaffolds full landing pages automatically.",
		tags: ["Astro", "Strapi", "GraphQL", "Tailwind CSS"],
		image: pagebuilder,
		alt: "Page Builder landing-page generator interface.",
	},
	{
		title: "Kairos List",
		description:
			'An AI-assisted bucket list. Enter a few dreams and the AI builds a psychological profile, then suggests goals that fit you. A "dream concierge" assistant helps you make them happen — from permits and gear to training and nutrition plans for, say, climbing Kilimanjaro.',
		tags: ["Next.js", "OpenAI API", "Firebase", "Tailwind CSS", "Vercel"],
		image: kairos,
		alt: "Kairos List AI-assisted bucket list interface.",
	},
];
---

<section id="work" class="container-page" aria-labelledby="work-heading">
	<h2 id="work-heading" class="eyebrow">Selected work</h2>

	<div class="mt-6 flex flex-col gap-16 md:gap-24">
		{
			projects.map((project, index) => (
				<article class="grid items-center gap-10 md:grid-cols-2 md:gap-14">
					{/* Product screenshot — first in DOM so it sits above the copy on mobile */}
					<figure
						class:list={[
							"relative",
							index % 2 === 0 ? "md:order-2" : "md:order-1",
						]}
					>
						<Image
							src={project.image}
							alt={project.alt}
							loading="lazy"
							decoding="async"
							class="w-full rounded-card border border-border shadow-glow"
						/>
					</figure>

					{/* Copy */}
					<div
						class:list={[
							"flex flex-col gap-5",
							index % 2 === 0 ? "md:order-1" : "md:order-2",
						]}
					>
						<h3 class="text-balance text-section">{project.title}</h3>
						<p class="max-w-md text-pretty text-body text-ink-secondary">
							{project.description}
						</p>

						<ul class="flex flex-wrap gap-2" role="list">
							{project.tags.map((tag) => (
								<li class="rounded-full border border-border bg-surface px-3 py-1.5 text-small text-ink-secondary">
									{tag}
								</li>
							))}
						</ul>
					</div>
				</article>
			))
		}
	</div>
</section>
