---
/**
 * TopoTexture — seamless topographic contour pattern as a subtle, decorative
 * background layer. Purely decorative → hidden from assistive tech.
 */
import patternUrl from "../assets/pattern.svg?url";

interface Props {
	/** Extra classes (e.g. z-index) for the wrapper. */
	class?: string;
	/** Layer opacity (0–1). */
	opacity?: number;
	/** Tile size in px on mobile — controls the pattern's on-screen scale. */
	size?: number;
	/** Tile size in px from the md breakpoint (768px) up. Defaults to `size`. */
	sizeMd?: number;
	/**
	 * Pin to the viewport (page-wide backdrop) instead of the parent box.
	 * Fixed → anchored in the top-right corner; otherwise centered on the
	 * right edge of the parent.
	 */
	fixed?: boolean;
}

const {
	class: className = "",
	opacity = 0.15,
	size = 500,
	sizeMd = 900,
	fixed = false,
} = Astro.props;

// Fixed: fade out from the top-right corner so the texture only tints that
// corner of the viewport. Default: centered on the right edge and fully
// transparent before the left half.
const maskFade = fixed
	? "radial-gradient(50% 75% at 75% 50%, #000 25%, transparent 75%)"
	: "radial-gradient(50% 100% at 80% 50%, #000 22%, transparent 72%)";

const positionClass = fixed
	? "absolute inset-0 bg-right"
	: "absolute inset-0 bg-center md:bg-right";
---

<div
	class:list={["topo-layer pointer-events-none", positionClass, className]}
	style={`background-image:url('${patternUrl}');--topo-size:${size}px;--topo-size-md:${sizeMd}px;opacity:${opacity};-webkit-mask-image:${maskFade};mask-image:${maskFade}`}
	aria-hidden="true"
>
</div>

<style>
	/* background-size can't live in a media query via inline style, so drive it
	   from CSS vars set on the element. */
	.topo-layer {
		background-size: var(--topo-size);
	}
	@media (min-width: 768px) {
		.topo-layer {
			background-size: var(--topo-size-md);
		}
	}
</style>

