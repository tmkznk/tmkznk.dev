---
import RoutePath from "../assets/route-path.svg";
---

<section class="relative overflow-hidden !pt-0" aria-labelledby="hero-heading">
	<!-- Decorative route ending in a location marker (echoes the map motif) -->
	<div
		aria-hidden="true"
		class="pointer-events-none absolute inset-0 -z-10"
	>
		<div class="container-page h-full md:relative">
			<!-- Mobile: positioned against the full section (stable on resize).
			     Desktop (md+): the wrapper becomes `relative`, so it aligns to the container. -->
			<RoutePath
				class="hidden lg:block absolute right-[-3.5rem] top-[36px] h-[58%] w-auto -scale-x-100 md:bottom-0 md:right-[20%] md:top-auto md:h-[80%] md:scale-x-100"
			/>
		</div>
	</div>

	<div class="container-page flex flex-col gap-8 pt-10 md:pt-16">
		<!-- Eyebrow -->
		<p class="flex items-center gap-2">
			<svg
				class="h-4 w-4 text-accent"
				viewBox="0 0 24 24"
				fill="none"
				stroke="currentColor"
				stroke-width="2"
				stroke-linecap="round"
				stroke-linejoin="round"
				aria-hidden="true"
			>
				<circle cx="12" cy="12" r="10"></circle>
				<polygon
					points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"
				></polygon>
			</svg>
			<span class="eyebrow text-accent">Hello</span>
		</p>

		<!-- Heading -->
		<h1
			id="hero-heading"
			class="max-w-[90%] text-balance font-bold leading-[0.95] tracking-tight text-[clamp(2.25rem,9.5vw,3.25rem)] md:max-w-3xl md:text-hero-lg"
		>
			I build<br />digital products<br />people <span class="accent">love.</span>
		</h1>

		<!-- Intro -->
		<p class="text-body text-ink-secondary max-w-[90%] text-pretty md:max-w-xl">
			Senior Front-End Engineer with 10+ years of experience building scalable
			web applications with React, TypeScript, Next.js and Astro.
		</p>

		<!-- CTAs -->
		<div class="flex flex-col gap-4 sm:flex-row">
			<a href="#work" class="btn btn-primary">
				See my work
				<svg
					class="h-5 w-5"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					stroke-linecap="round"
					stroke-linejoin="round"
					aria-hidden="true"
				>
					<path d="M5 12h14"></path>
					<path d="m12 5 7 7-7 7"></path>
				</svg>
			</a>
			<a href="/tmkznk.dev/CV_Tomasz_Zienkowicz_2026_en.pdf" class="btn btn-secondary" download>
				Download CV
				<svg
					class="h-5 w-5"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					stroke-linecap="round"
					stroke-linejoin="round"
					aria-hidden="true"
				>
					<path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
					<polyline points="7 10 12 15 17 10"></polyline>
					<line x1="12" y1="15" x2="12" y2="3"></line>
				</svg>
			</a>
		</div>
	</div>
</section>
