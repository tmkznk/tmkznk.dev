---
import TopoBackground from "./TopoBackground.astro";
---

<section class="relative" aria-labelledby="hero-heading">
	<!-- <TopoBackground /> -->

	<div class="container-page flex flex-col gap-8 pt-10 md:pt-16">
		<!-- Eyebrow -->
		<p class="flex items-center gap-2">
			<svg
				class="h-4 w-4 text-accent"
				viewBox="0 0 24 24"
				fill="none"
				stroke="currentColor"
				stroke-width="2"
				stroke-linecap="round"
				stroke-linejoin="round"
				aria-hidden="true"
			>
				<path d="M7 20h10"></path>
				<path d="M10 20c5.5-2.5.8-6.4 3-10"></path>
				<path
					d="M9.5 9.4c1.1.8 1.8 2.2 2.3 3.7-2 .4-3.5.4-4.8-.3-1.2-.6-2.3-1.9-3-4.2 2.8-.5 4.4 0 5.5.8z"
				></path>
				<path
					d="M14.1 6a7 7 0 0 0-1.1 4c1.9-.1 3.3-.6 4.3-1.4 1-1 1.6-2.3 1.7-4.6-2.7.1-4 1-4.9 2z"
				></path>
			</svg>
			<span class="eyebrow text-accent">Hello</span>
		</p>

		<!-- Heading -->
		<h1
			id="hero-heading"
			class="max-w-3xl text-balance font-bold leading-[0.95] tracking-tight text-[clamp(2.25rem,9.5vw,3.25rem)] md:text-hero-lg"
		>
			I build<br />digital products<br />people <span class="accent">love.</span>
		</h1>

		<!-- Intro -->
		<p class="text-body text-ink-secondary max-w-xl text-pretty">
			Senior Front-End Engineer with 10+ years of experience building scalable
			web applications with React, TypeScript, Next.js and Astro.
		</p>

		<!-- CTAs -->
		<div class="flex flex-col gap-4 sm:flex-row">
			<a href="#work" class="btn btn-primary">
				See my work
				<svg
					class="h-5 w-5"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					stroke-linecap="round"
					stroke-linejoin="round"
					aria-hidden="true"
				>
					<path d="M5 12h14"></path>
					<path d="m12 5 7 7-7 7"></path>
				</svg>
			</a>
			<a href="/cv.pdf" class="btn btn-secondary" download>
				Download CV
				<svg
					class="h-5 w-5"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					stroke-linecap="round"
					stroke-linejoin="round"
					aria-hidden="true"
				>
					<path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
					<polyline points="7 10 12 15 17 10"></polyline>
					<line x1="12" y1="15" x2="12" y2="3"></line>
				</svg>
			</a>
		</div>
	</div>
</section>
