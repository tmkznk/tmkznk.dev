---
import "../styles/global.css";

interface Props {
	title?: string;
	description?: string;
}

const {
	title = "tmkznk.dev — Build. Optimize. Explore.",
	description = "Senior Front-End Engineer with 10+ years of experience building scalable web applications with React, TypeScript, Next.js and Astro.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />

		<!-- Fonts: Inter (app) + Newsreader Italic (accents) -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Newsreader:ital,wght@1,400&display=swap"
			rel="stylesheet"
		/>

		<title>{title}</title>
	</head>
	<body>
		<slot />
	</body>
</html>
