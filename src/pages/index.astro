---
import Layout from "../layouts/Layout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import Hero from "../components/Hero.astro";
import TechStack from "../components/TechStack.astro";
import ExperienceHighlights from "../components/ExperienceHighlights.astro";
import SelectedWork from "../components/SelectedWork.astro";
import MyPrinciples from "../components/MyPrinciples.astro";
import About from "../components/About.astro";
import CtaBanner from "../components/CtaBanner.astro";
import SiteFooter from "../components/SiteFooter.astro";
import TopoTexture from "../components/TopoTexture.astro";
---

<Layout>
	<SiteHeader />
	<main
		id="main-content"
		class="flex flex-col gap-16 pb-section [&>section]:pt-6"
	>
		<TopoTexture fixed opacity={0.15} />
		<Hero />
		<TechStack />
		<ExperienceHighlights />
		<SelectedWork />
		<MyPrinciples />
		<About />
		<CtaBanner />
	</main>
	<SiteFooter />
</Layout>
